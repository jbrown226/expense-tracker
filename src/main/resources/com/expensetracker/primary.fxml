<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ComboBox?>

<!-- container for left and right panels -->
<HBox xmlns="http://javafx.com"
      xmlns:fx="http://javafx.com"
      fx:controller="com.expensetracker.PrimaryController"
      spacing="20.0" 
      alignment="CENTER"
      prefWidth="200.0" prefHeight="400.0">
      
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <!-- left panel: add expenses -->
    <VBox spacing="10.0" alignment="TOP_CENTER" HBox.hgrow="ALWAYS">
        <Label text="New Expense" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
        <TextField fx:id="expenseInput" promptText="Name of expense"/>
        <TextField fx:id="amountInput" promptText="Amount"/>
        <TextField fx:id="descriptionInput" promptText="Description"/>
        <TextField fx:id="contactPhoneInput" promptText="Phone Number"/>
        <ComboBox fx:id="categoryComboBox" promptText="Frequency"/>
        <Button text="Create Expense" onAction="#addItem" maxWidth="Infinity"/>
    </VBox>

    <!-- right panel: expense list -->
    <VBox spacing="10.0" alignment="TOP_CENTER" HBox.hgrow="ALWAYS">
        <Label text="Expense List" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
        <ListView fx:id="expenseListView" VBox.vgrow="ALWAYS"/>
        
     
        <HBox spacing="15.0" alignment="CENTER_LEFT" prefWidth="250.0">

            <Label fx:id="totalAmountLabel" style="-fx-font-weight: bold;"/>

            <padding>
                <Insets top="5.0" right="5.0" bottom="5.0" left="5.0"/>
            </padding>
        </HBox>
    </VBox>
  </HBox>