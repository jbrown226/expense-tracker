<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>

<GridPane xmlns="http://javafx.com/javafx"
          xmlns:fx="http://javafx.com/fxml"
          fx:controller="com.expensetracker.ExpenseDetailsController"
          hgap="12"
          vgap="12"
          prefWidth="400"
          prefHeight="230">

       <padding>
              <Insets top="20" right="20" bottom="20" left="20"/>
       </padding>

       <Label text="Name:"
              style="-fx-font-weight: bold;"
              GridPane.columnIndex="0"
              GridPane.rowIndex="0"/>

       <Label fx:id="nameLabel"
              wrapText="true"
              maxWidth="260"
              GridPane.columnIndex="1"
              GridPane.rowIndex="0"/>

       <Label text="Monthly amount:"
              style="-fx-font-weight: bold;"
              GridPane.columnIndex="0"
              GridPane.rowIndex="1"/>

       <Label fx:id="amountLabel"
              GridPane.columnIndex="1"
              GridPane.rowIndex="1"/>

       <Label text="Contact Phone:"
              style="-fx-font-weight: bold;"
              GridPane.columnIndex="0"
              GridPane.rowIndex="2"/>

       <Label fx:id="contactPhoneLabel"
              wrapText="true"
              maxWidth="260"
              GridPane.columnIndex="1"
              GridPane.rowIndex="2"/>

       <Label text="Description:"
              style="-fx-font-weight: bold;"
              GridPane.columnIndex="0"
              GridPane.rowIndex="3"/>

       <Label fx:id="descriptionLabel"
              wrapText="true"
              maxWidth="260"
              GridPane.columnIndex="1"
              GridPane.rowIndex="3"/>

       <Label text="Frequency:"
              style="-fx-font-weight: bold;"
              GridPane.columnIndex="0"
              GridPane.rowIndex="4"/>

       <Label fx:id="frequencyLabel"
              GridPane.columnIndex="1"
              GridPane.rowIndex="4"/>
             
       <HBox spacing="10"
              alignment="CENTER_RIGHT"
              GridPane.columnIndex="0"
              GridPane.columnSpan="2"
              GridPane.rowIndex="5">

                     <Button text="Delete"
                            onAction="#deleteExpense"/>

                     <Button text="Close"
                            defaultButton="true"
                            onAction="#closeWindow"/>
       </HBox>
</GridPane>
